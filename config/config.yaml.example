# Paigram Configuration Example

app:
  name: "Paigram User Center"
  host: "0.0.0.0"
  port: 8080
  mode: "debug" # debug, release, test

database:
  addr: "localhost:3306"
  username: "root"
  password: "password"
  dbname: "paigram"
  config: "charset=utf8mb4&parseTime=True&loc=Local"
  migrations_dir: "initialize/migrate/sql"
  max_idle_conns: 10
  max_open_conns: 100
  log_mode: "info"
  log_zap: true
  slow_threshold: 200
  auto_migrate: true

auth:
  access_token_ttl: 3600         # 1 hour
  refresh_token_ttl: 2592000     # 30 days
  email_verification_ttl: 86400  # 24 hours
  oauth_state_ttl: 600          # 10 minutes
  telegram_bot_token: "YOUR_TELEGRAM_BOT_TOKEN"  # Get from @BotFather
  allowed_providers:
    - google
    - github
    - telegram
  oauth:
    google:
      client_id: "your-google-client-id"
      client_secret: "your-google-client-secret"
      redirect_url: "http://localhost:8080/api/v1/auth/oauth/google/callback"
      auth_url: "https://accounts.google.com/o/oauth2/v2/auth"
      token_url: "https://oauth2.googleapis.com/token"
      user_info_url: "https://www.googleapis.com/oauth2/v2/userinfo"
      scopes:
        - openid
        - email
        - profile
    github:
      client_id: "your-github-client-id"
      client_secret: "your-github-client-secret"
      redirect_url: "http://localhost:8080/api/v1/auth/oauth/github/callback"
      auth_url: "https://github.com/login/oauth/authorize"
      token_url: "https://github.com/login/oauth/access_token"
      user_info_url: "https://api.github.com/user"
      scopes:
        - user:email

redis:
  enabled: true
  addr: "localhost:6379"
  username: ""
  password: ""
  db: 0
  prefix: "paigram:"
  dial_timeout: 5
  read_timeout: 3
  write_timeout: 3
  pool_size: 10
  min_idle_conns: 5
  max_retries: 3

grpc:
  enabled: true
  port: 50051
  max_connection_idle: 300       # seconds
  max_connection_age: 3600       # seconds
  max_connection_age_grace: 30   # seconds
  keepalive_time: 600           # seconds
  keepalive_timeout: 20         # seconds